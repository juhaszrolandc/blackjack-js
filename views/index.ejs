<!DOCTYPE html>
<html lang="hu"><head>

    <meta charset="UTF-8">
    <link type="text/css" href="css/style.css" rel="stylesheet">
    <title>Black Jack Game</title>

    <script>

        window.addEventListener("beforeunload", function (e) {
            e.preventDefault();
        });
        
        function newRound(){
            const xhttp = new XMLHttpRequest();
            
            xhttp.onreadystatechange = function() {
                if( this.readyState === 4 && this.status === 200 ){
                    //document.innerText = this.responseText;
                }
            }
            xhttp.open("GET", "new-round", true); // isAssincron = true;
            xhttp.send();
        }

        function hit(){
            const xhttp = new XMLHttpRequest();
            
            xhttp.onreadystatechange = function() {
                if( this.readyState === 4 && this.status === 200 ){
                    document.innerText = this.responseText;
                }
            }
            xhttp.open("GET", "hit", true); // isAssincron = true;
            xhttp.send();
        }

        function stand(){
            const xhttp = new XMLHttpRequest();
            
            xhttp.onreadystatechange = function() {
                if( this.readyState === 4 && this.status === 200 ){
                    document.innerText = this.responseText;
                }
            }
            xhttp.open("GET", "stand", true); // isAssincron = true;
            xhttp.send();
        }

    </script>

</head><body>

    <div id="tableContainer">
        <div id="leftSide">
            <div class="handContainer" id="playerHandContainer"></div>
            <p>
                <span>Player:</span>
                <span id="playerHandValue"></span>
                <span> | </span>
                <span>Chips: </span>
                <span id="chipsCount"></span>
            </p>
        </div>

        <div id="rightSide">
            <div class="handContainer" id="dealerHandContainer"></div>
            <p>
                <span>Dealer:</span>
                <span id="dealerHandValue"></span>
            </p>
        </div>
    </div>

    <p id="message"></p>

    <div id="buttonContainer">
        <button id="hitBtn" onclick="hit()">Hit</button>
        <button id="standBtn" onclick="stand()">Stand</button>
        <button id="startBtn" onclick="newRound()">New Round</button>
    </div>

</body></html>